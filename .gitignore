# ========================================
# Animal Shelter — .gitignore
# ========================================

# ── 빌드 산출물 (컴파일된 결과물, 다시 만들 수 있는 것들) ──
build/
target/
out/
*.class

# ── DB 비밀번호 / 인증정보 ★ 절대 올리지 마세요 ──
resources/config/db.properties
**/db.properties

# ── Eclipse 개인 설정 (다른 컴퓨터에 의미 없음) ──
.settings/
.project
.classpath
.factorypath
.apt_generated/
.springBeans
.sts4-cache/

# ── IntelliJ IDEA ──
.idea/
*.iml
*.ipr
*.iws

# ── Maven ──
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ── 로그 파일 ──
*.log
logs/

# ── OS 자동 생성 파일 ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Tomcat / 서버 작업 디렉터리 ──
tomcat/work/
work/

# ── 업로드된 파일들 (사용자 업로드 이미지 등 — 코드 아니므로 제외) ──
uploads/
upload/
src/main/webapp/uploads/
src/main/webapp/upload/
